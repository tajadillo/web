[cpu_usage]
label= пЛЫ
command=sh -c 'read cpu user nice system idle rest < /proc/stat; usage=$((100 * (user + system) / (user + system + idle))); echo "CPU: $usage%"'
interval=2
#color=#FFD700
color=#000000

# Block for memory usage (commented out in your config)
[memory]
label= оњЕ  RAM
command=free -h | grep Mem | awk '{print $3 "/" $2}'
interval=1
color=#ffcc00

[temperature]
label=пЛЙ TEMP
command= bash -c 'temp=$(sensors | grep -oP "(temp1:|Core [0-9]):\s*\+([0-9.]+)" | head -n 1 | sed -E "s/[^0-9.]//g"); if [ -z "$temp" ]; then echo "N/A"; else echo "$temp¬∞C"; fi'
interval=1
color=#ff00ff

# Block for the time
[time]
label= пАЧ
#command=date '+%Y-%m-%d %H:%M:%S'
#command=date '+%H:%M:%S %d-%m-%Y'
command=date +%T
interval=1
color=#808080

[wifi]
label= пЗЂ
command=bash -c 'iface=$(ip link | awk -F: "/wlp|wlan/{print \$2}" | tr -d " "); if [ -n "$iface" ]; then ssid=$(iw dev "$iface" info | grep ssid | awk "{print \$2}"); if [ -n "$ssid" ]; then echo "$ssid"; else echo " Desconectado"; fi; else echo "No WiFi Interface"; fi'
interval=1
color=#51a3a3

