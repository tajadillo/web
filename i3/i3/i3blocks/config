[ip]
#command=hostname -i | awk '{ print "IP:" $1 }'
label= оЉЙ .
command=ip addr | grep 192 | awk '{print $2}' | sed 's/\/.*//g'
interval=60
color=#ee3333
#border=#91E78B

# Block for battery status (if applicable)
[battery]
label= пЙВ .
command=acpi -b | grep -oP '\d+(?=%)' | awk '{print $1 "%"}' ''
interval=60
