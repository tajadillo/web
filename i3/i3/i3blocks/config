[temperature]
label=ï‹‰ TEMP
command= bash -c 'temp=$(sensors | grep -oP "(temp1:|Core [0-9]):\s*\+([0-9.]+)" | head -n 1 | sed -E "s/[^0-9.]//g"); if [ -z "$temp" ]; then echo "N/A"; else echo "$tempÂ°C"; fi'
interval=1
